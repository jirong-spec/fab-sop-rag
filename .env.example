# ═══════════════════════════════════════════════════════════════════════════
# Fab SOP Knowledge Query API — Environment Variables
#
# Copy this file to .env and edit values as needed.
#   cp .env.example .env
#
# Docker Compose automatically substitutes ${VAR} references in
# docker-compose.yml from this file. The api container also loads it via
# env_file, but the compose file overrides the three networking vars
# (NEO4J_URI, OPENAI_API_BASE, QDRANT_URL) to use Docker service names.
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────────────────
# LLM_MODEL_DIR : host path to the directory containing downloaded model weights.
#                 Mounted into the vllm container as /llm (read-only).
#                 Default: /opt/models  (override for non-standard layouts)
LLM_MODEL_DIR=/opt/models

# LLM_MODEL : served model name used in OpenAI API calls (--served-model-name).
#             The vLLM container loads the weights from the LLM_MODEL_DIR path above;
#             this name must match docker-compose.yml's --served-model-name.
OPENAI_API_KEY=EMPTY
# Local dev (outside Docker): http://localhost:8299/v1
# docker-compose.yml overrides this to http://vllm:8000/v1 for internal networking
OPENAI_API_BASE=http://localhost:8299/v1
LLM_MODEL=Qwen2.5-7B-Instruct-AWQ-int4
LLM_TIMEOUT=30.0

# Optional: set if the model requires HuggingFace authentication
# HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── Neo4j ─────────────────────────────────────────────────────────────────
# docker-compose.yml sets NEO4J_AUTH using NEO4J_USERNAME/NEO4J_PASSWORD
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123

# ── Vector store (Qdrant) ─────────────────────────────────────────────────
# QDRANT_URL is overridden to http://qdrant:6333 by docker-compose.yml.
# For local dev WITHOUT Docker, point at the Qdrant server:
#   QDRANT_URL=http://localhost:6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sop_docs
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── Retrieval ─────────────────────────────────────────────────────────────
DEFAULT_MAX_HOP=2
DEFAULT_TOP_K=4
# GRAPH_TRAVERSAL_MODE: distinct (default) | undirected | directed
#   distinct   = collect distinct edges within hop (no LIMIT-200 path truncation)
#   undirected = both-direction paths, LIMIT 200
#   directed   = outgoing-only paths — lower recall, not recommended
GRAPH_TRAVERSAL_MODE=distinct

# ── Guardrail fallback policies ───────────────────────────────────────────
# topic_fallback_policy:     lenient = allow + warn | strict = block
# grounding_fallback_policy: strict  = flag ungrounded | lenient = allow + warn
TOPIC_FALLBACK_POLICY=lenient
GROUNDING_FALLBACK_POLICY=strict

# ── Authentication ─────────────────────────────────────────────
# Set API_KEY to a non-empty string to require X-API-Key header on /v1/* endpoints.
# Leave empty to disable auth (suitable for internal demos and PoC).
API_KEY=
